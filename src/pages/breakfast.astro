---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Breakfast | Beach House Restaurant" description="Breakfast served daily 7am-1:30pm at Beach House Restaurant. Classic diner favorites with beach-themed combos. Cash only.">

  <section class="page-hero">
    <div class="container">
      <span class="hero-badge">Served Daily</span>
      <h1>Breakfast</h1>
      <p class="hero-sub">7am &ndash; 1:30pm &middot; Cash Only</p>
    </div>
    <svg class="hero-wave" viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="var(--cream)" />
    </svg>
  </section>

  <section class="page-body">
    <div class="container">

      <!-- COMBOS -->
      <div class="menu-section">
        <h2>Beach Combos</h2>
        <p class="menu-note">Cellone's toast or English muffin with butter and jelly. Egg whites only add $1.25.</p>
        <div class="menu-grid">
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sunrise</span><span class="item-price">$8.95</span></div>
            <p class="item-desc">2 eggs, bacon or sausage links, home fries &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Big Surf</span><span class="item-price">$8.95</span></div>
            <p class="item-desc">2 eggs, mild or hot Italian sausage or ham, 2 pancakes or French toast, home fries</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Big Beach</span><span class="item-price">$9.95</span></div>
            <p class="item-desc">3 eggs, bacon, ham &amp; home fries, toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Tidal Wave</span><span class="item-price">$10.95</span></div>
            <p class="item-desc">2 eggs, bacon or sausage or ham, 2 pancakes or French toast, home fries &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Wave Runner</span><span class="item-price">$10.95</span></div>
            <p class="item-desc">2 eggs, hot or mild Italian sausage or ham, 1 steak &amp; 2 pancakes or French toast, home fries</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sunny Beach</span><span class="item-price">$7.95</span></div>
            <p class="item-desc">2 eggs, bacon or Italian rope sausage &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Little Surf</span><span class="item-price">$5.25</span></div>
            <p class="item-desc">2 eggs, bacon or Italian rope sausage &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Baby Beach</span><span class="item-price">$4.95</span></div>
            <p class="item-desc">1 egg, bacon or Italian rope sausage &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Light Beach</span><span class="item-price">$3.95</span></div>
            <p class="item-desc">1 egg &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">King of the Beach</span><span class="item-price">$11.95</span></div>
            <p class="item-desc">3 eggs, choice of 2 meats, home fries &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Day at the Beach</span><span class="item-price">$10.95</span></div>
            <p class="item-desc">2 eggs, corned beef hash, home fries &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">The Beach Bum</span><span class="item-price">$11.95</span></div>
            <p class="item-desc">Steak &amp; eggs, home fries &amp; toast</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sand Dollar</span><span class="item-price">$3.75</span></div>
            <p class="item-desc">2 pancakes or 2 slices of French toast, hot or mild sausage</p>
          </div>
        </div>
      </div>

      <!-- GRIDDLE -->
      <div class="menu-section">
        <h2>From the Griddle</h2>
        <p class="menu-note">No substitutions please.</p>
        <div class="menu-grid">
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Hotcake Stacks</span><span class="item-price">$6.95</span></div>
            <p class="item-desc">3 large buttermilk pancakes. Add choice of chocolate chips, blueberries, or bananas $8.25.</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Strawberry Stacks</span><span class="item-price">$9.95</span></div>
            <p class="item-desc">3 large buttermilk pancakes topped with strawberries, whipped cream &amp; powdered sugar</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Blueberry Only Stacks</span><span class="item-price">$8.95</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Pineapple Upside Down Cakes</span><span class="item-price">$7.75</span></div>
