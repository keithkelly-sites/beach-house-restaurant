        <h2>Breakfast Sandwiches</h2>
        <p class="menu-note">Served with beach potatoes.</p>
        <div class="menu-grid">
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sunrise Sandwich</span><span class="item-price">$3.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Breakfast Quesadilla</span><span class="item-price">$11.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Breakfast Hoagie</span><span class="item-price">$12.25</span></div>
          </div>
