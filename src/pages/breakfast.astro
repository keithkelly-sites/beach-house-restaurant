          <div class="menu-item">
            <div class="item-header"><span class="item-name">Omelet's Delight</span><span class="item-price">$8.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Ham &amp; Cheese</span><span class="item-price">$10.75</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Bacon &amp; Cheese</span><span class="item-price">$10.75</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sausage &amp; Cheese</span><span class="item-price">$10.75</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Western</span><span class="item-price">$11.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Italian</span><span class="item-price">$12.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Greek</span><span class="item-price">$11.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Mushroom &amp; Cheese</span><span class="item-price">$9.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sicilian</span><span class="item-price">$12.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Buffalo Chicken</span><span class="item-price">$12.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Tomato &amp; Blue Cheese</span><span class="item-price">$12.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Burger</span><span class="item-price">$12.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Corned Beef Hash</span><span class="item-price">$12.25</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Veggie</span><span class="item-price">$10.75</span></div>
          </div>
        </div>
      </div>

      <!-- SCRAMBLERS -->
      <div class="menu-section">
        <h2>Scramblers</h2>
        <div class="menu-grid">
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Bacon Scrambler</span><span class="item-price">$10.75</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Veggie Scrambler</span><span class="item-price">$10.75</span></div>
