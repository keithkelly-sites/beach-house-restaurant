          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">1 French Toast</span><span class="item-price">$3.75</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">English Muffin</span><span class="item-price">$1.95</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Sausage Links</span><span class="item-price">$3.75</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Bacon</span><span class="item-price">$3.75</span></div>
