          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Brown Sugar Cinnamon French Toast</span><span class="item-price">$8.95</span></div>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Apple Pie French Toast</span><span class="item-price">$8.95</span></div>
            <p class="item-desc">3 slices of French toast filled with apple pie filling, topped with powdered sugar</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Waffle</span><span class="item-price">$5.95</span></div>
            <p class="item-desc">Add blueberries, strawberries &amp; whipped cream $6.75</p>
          </div>
          <div class="menu-item">
            <div class="item-header"><span class="item-name">Nutella Pancakes or French Toast</span><span class="item-price">$8.95</span></div>
            <p class="item-desc">3 large buttermilk pancakes or 3 slices of French toast stuffed with Nutella, strawberries, sliced milk &amp; coconut</p>
          </div>
        </div>
      </div>

      <!-- BREAKFAST SANDWICHES -->
