  <section class="page-cta">
    <div class="container text-center">
      <p class="cta-heading">One mile past Trax Farms on Route 88.</p>
      <p class="cta-sub">Open daily at 7am. Breakfast only on Sundays.</p>
      <a href="tel:+17243487022" class="btn btn-primary">Call 724-348-7022</a>
    </div>
  </section>

</Layout>

<style>
  :global(.site-footer) {
    --footer-wave-fill: var(--ocean);
  }

  /* Menu sections */
  .menu-section {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--sand-dark);
  }

  .menu-section:last-of-type {
    border-bottom: none;
  }

  .menu-section h2 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-xs);
    color: var(--charcoal);
  }

  .menu-note {
    font-size: var(--font-size-sm);
    color: var(--warm-brown-light);
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  /* Menu grid */
  .menu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  .menu-item {
    padding: var(--space-sm) 0;
    border-bottom: 1px dotted var(--sand-dark);
  }

  .menu-item:last-child {
    border-bottom: none;
  }

  .item-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .item-name {
    font-family: var(--font-display);
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--charcoal);
  }

  .item-price {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--ocean);
    white-space: nowrap;
  }

  .item-price.refill {
    font-size: var(--font-size-xs);
    color: var(--warm-brown-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .item-desc {
    font-size: var(--font-size-sm);
    color: var(--warm-brown);
    line-height: 1.5;
    margin-top: 0.15em;
  }

  /* Build your own */
  .highlight-section {
    background: var(--ocean-faded);
    padding: var(--space-md);
    border-radius: var(--radius);
    border-bottom: none;
  }

  .build-options {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  .build-col h3 {
    font-size: var(--font-size-base);
    margin-bottom: 0.2em;
  }

  @media (min-width: 40rem) {
    .menu-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: var(--space-lg);
    }

    .menu-grid.compact {
      grid-template-columns: repeat(3, 1fr);
    }

    .build-options {
      grid-template-columns: repeat(3, 1fr);
    }

    .photo-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
