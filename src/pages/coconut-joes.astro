---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import cjPatio from '../assets/images/coconut-joes-01.jpg';
import cjBikeNight from '../assets/images/coconut-joes-02.jpg';
import cjLogo from '../assets/images/coconut-joes-logo.jpg';
---

<Layout title="Coconut Joe's Tiki Bar | Beach House Restaurant" description="Coconut Joe's Tiki Bar at Beach House Restaurant. Bike Night Thursdays, Car Cruise Fridays, Live Music Sundays. Outdoor patio bar in Finleyville, PA.">

  <section class="tiki-hero grain">
    <div class="tiki-hero-bg">
      <Image
        src={cjPatio}
        alt="Coconut Joe's Tiki Bar outdoor patio with colorful umbrellas and string lights"
        class="hero-img"
        loading="eager"
        width={1200}
        height={800}
        layout="constrained"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <Image
        src={cjLogo}
        alt="Coconut Joe's Tiki Bar logo"
        class="tiki-logo"
        width={120}
        height={120}
        loading="eager"
        layout="constrained"
      />
      <h1>Coconut Joe's<br />Tiki Bar</h1>
      <p class="hero-tagline">The outdoor bar at Beach House Restaurant</p>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,30 C480,80 960,0 1440,50 L1440,80 L0,80 Z" fill="var(--cream)" />
      </svg>
    </div>
  </section>

  <section class="events section">
    <div class="container">
      <h2 class="section-heading">Weekly Events</h2>

      <div class="events-grid">
        <div class="event-card">
          <div class="event-day">Thursday</div>
          <h3>Bike Night</h3>
          <p>Chrome and cold drinks. The parking lot fills up with bikes every Thursday night.</p>
        </div>

        <div class="event-card featured">
          <div class="event-day">Friday</div>
          <h3>Car Cruise</h3>
          <p>Classics, customs, and hot rods. Bring yours or just come to look.</p>
        </div>

        <div class="event-card">
          <div class="event-day">Sunday</div>
          <h3>Live Music</h3>
          <p>Local bands on the outdoor stage. The best way to close out the weekend.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bike-night grain">
    <div class="container">
      <div class="split-layout">
        <div class="split-image">
          <Image
            src={cjBikeNight}
            alt="Bike night at Coconut Joe's with rows of motorcycles at sunset"
            loading="lazy"
            class="vintage-photo"
            width={800}
            height={600}
            layout="constrained"
          />
        </div>
        <div class="split-content">
          <h2>Thursday nights get loud</h2>
          <p>Bike Night at Coconut Joe's has become a Route 88 tradition. Riders from all over western PA line up their bikes while the tiki bar keeps the drinks cold and the music rolling.</p>
          <p>No cover, no sign-up. Just show up.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="tiki-cta">
    <div class="container text-center">
      <h2>Find us on Route 88</h2>
      <p class="cta-sub">One mile past Trax Farms, Finleyville, PA</p>
      <a href="tel:+17243487022" class="btn btn-outline">Call 724-348-7022</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .tiki-hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .tiki-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      oklch(0.15 0.02 60 / 0.95) 0%,
      oklch(0.15 0.02 60 / 0.6) 40%,
      oklch(0.15 0.02 60 / 0.2) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 3;
    padding-bottom: var(--space-2xl);
  }

  .tiki-logo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--sun);
    margin-bottom: var(--space-md);
  }

  .tiki-hero h1 {
    font-size: var(--font-size-3xl);
    font-weight: 900;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: var(--space-sm);
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-style: italic;
    color: var(--sun);
  }

  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 4;
  }

  .hero-wave svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Events */
  .section-heading {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .events-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .event-card {
    background: var(--sand);
    padding: var(--space-lg);
    border-radius: var(--radius);
    text-align: center;
    transition: transform 0.3s ease;
  }

  .event-card:hover {
    transform: translateY(-4px);
  }

  .event-card.featured {
    background: var(--charcoal);
    color: var(--sand);
  }

  .event-card.featured .event-day {
    color: var(--sun);
  }

  .event-card.featured h3 {
    color: var(--white);
  }

  .event-day {
    font-family: var(--font-body);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ocean);
    margin-bottom: var(--space-xs);
  }

  .event-card h3 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-xs);
  }

  .event-card p {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--warm-brown);
  }

  .event-card.featured p {
    color: var(--sand-dark);
  }

  /* Bike Night split */
  .bike-night {
    background: var(--sand);
    padding: var(--space-xl) 0;
    margin-top: var(--space-lg);
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .split-image {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 4px 30px oklch(0.25 0.015 60 / 0.12);
  }

  .split-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  .split-content h2 {
    margin-bottom: var(--space-sm);
  }

  .split-content p {
    font-size: var(--font-size-base);
    color: var(--warm-brown);
    line-height: 1.7;
  }

  /* CTA */
  .tiki-cta {
    padding: var(--space-xl) 0;
  }

  .tiki-cta h2 {
    margin-bottom: 0.3em;
  }

  .cta-sub {
    font-size: var(--font-size-base);
    color: var(--warm-brown);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 40rem) {
    .events-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .tiki-logo {
      width: 100px;
      height: 100px;
    }
  }

  @media (min-width: 52rem) {
    .split-layout {
      grid-template-columns: 1fr 1fr;
    }

    .tiki-hero h1 {
      font-size: var(--font-size-hero);
    }
  }
</style>
