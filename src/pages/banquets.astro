---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Beach Room Banquets | Beach House Restaurant" description="The Beach Room banquet facility in Finleyville, PA. Weddings, showers, birthday parties, and more. 2 bars, stage, dance floor, movie screen.">

  <section class="banquet-hero grain">
    <div class="container">
      <div class="hero-content">
        <span class="hero-badge">Private Events</span>
        <h1>The Beach<br />Room</h1>
        <p class="hero-lead">The Beach House's large banquet facility, perfect for weddings, showers, birthday parties, and more.</p>
      </div>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,20 C360,70 720,0 1080,50 C1260,70 1380,30 1440,40 L1440,80 L0,80 Z" fill="var(--cream)" />
      </svg>
    </div>
  </section>

  <section class="amenities section">
    <div class="container">
      <h2 class="section-heading">Everything you need for your event</h2>

      <div class="amenities-grid">
        <div class="amenity">
          <div class="amenity-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="4" y="28" width="32" height="4" rx="1" fill="currentColor" opacity="0.3"/>
              <rect x="8" y="20" width="10" height="8" rx="1" fill="currentColor"/>
              <rect x="22" y="20" width="10" height="8" rx="1" fill="currentColor"/>
              <rect x="14" y="8" width="12" height="12" rx="1" fill="currentColor" opacity="0.6"/>
            </svg>
          </div>
          <h3>2 Large Bars</h3>
          <p>Full-service bars to keep the celebration going.</p>
        </div>

        <div class="amenity">
          <div class="amenity-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <circle cx="20" cy="20" r="14" fill="currentColor" opacity="0.2"/>
              <path d="M15 16 L20 12 L25 16 L25 26 L15 26 Z" fill="currentColor"/>
              <rect x="18" y="22" width="4" height="4" rx="0.5" fill="var(--cream)"/>
            </svg>
          </div>
          <h3>Stage</h3>
          <p>Live music, speeches, performances. Room for a full band.</p>
        </div>

        <div class="amenity">
          <div class="amenity-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="6" y="10" width="28" height="20" rx="2" fill="currentColor"/>
              <rect x="8" y="12" width="24" height="16" rx="1" fill="var(--cream)"/>
              <polygon points="16,16 16,24 26,20" fill="currentColor" opacity="0.5"/>
            </svg>
          </div>
          <h3>Movie Screen</h3>
          <p>Theater-size screen with DVD capabilities. Slideshows, videos, whatever you need.</p>
        </div>

        <div class="amenity">
          <div class="amenity-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <ellipse cx="20" cy="30" rx="14" ry="4" fill="currentColor" opacity="0.2"/>
              <circle cx="14" cy="18" r="4" fill="currentColor" opacity="0.5"/>
              <circle cx="26" cy="18" r="4" fill="currentColor" opacity="0.5"/>
              <circle cx="20" cy="14" r="5" fill="currentColor"/>
            </svg>
          </div>
          <h3>Dance Floor</h3>
          <p>Enough room for the whole party to move.</p>
        </div>

        <div class="amenity">
          <div class="amenity-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="6" y="14" width="28" height="16" rx="2" fill="currentColor" opacity="0.3"/>
              <path d="M10 14 C10 10 14 8 20 8 C26 8 30 10 30 14" fill="currentColor"/>
              <circle cx="20" cy="22" r="3" fill="var(--cream)"/>
            </svg>
          </div>
          <h3>Sound System</h3>
          <p>Built-in sound so you don't have to bring your own.</p>
        </div>

        <div class="amenity">
          <div class="amenity-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="8" y="12" width="24" height="18" rx="2" fill="currentColor" opacity="0.2"/>
              <circle cx="16" cy="20" r="3" fill="currentColor"/>
              <circle cx="24" cy="20" r="3" fill="currentColor"/>
              <rect x="14" y="24" width="12" height="2" rx="1" fill="currentColor" opacity="0.5"/>
            </svg>
          </div>
          <h3>Flexible Catering</h3>
          <p>Bring your own caterer or choose from our in-house options. We work with all budgets.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="events-cta grain">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <h2>Let's plan your event</h2>
          <p>Weddings, showers, birthday parties, corporate events, reunions. We help bring your event vision to life, and we work with all budgets.</p>
          <div class="cta-contact">
            <p class="contact-name">Contact Debbie</p>
            <a href="tel:+14125080200" class="btn btn-primary">Call 412-508-0200</a>
          </div>
        </div>
        <div class="cta-details">
          <div class="detail">
            <span class="detail-label">Location</span>
            <span class="detail-value">6285 Route 88, Finleyville, PA 15332</span>
          </div>
          <div class="detail">
            <span class="detail-label">Best for</span>
            <span class="detail-value">Weddings, showers, birthdays, corporate events, reunions</span>
          </div>
          <div class="detail">
            <span class="detail-label">Catering</span>
            <span class="detail-value">In-house options or bring your own caterer</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .banquet-hero {
    background-color: var(--charcoal);
    padding: var(--space-2xl) 0 0;
    position: relative;
    overflow: hidden;
  }

  .banquet-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, oklch(0.52 0.1 230 / 0.15), transparent 60%),
      radial-gradient(ellipse at 20% 80%, oklch(0.87 0.14 88 / 0.08), transparent 50%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 36rem;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sun);
    margin-bottom: var(--space-sm);
  }

  .banquet-hero h1 {
    font-size: var(--font-size-hero);
    font-weight: 900;
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--space-md);
  }

  .hero-lead {
    font-size: var(--font-size-lg);
    color: var(--sand);
    line-height: 1.6;
    max-width: 28rem;
    padding-bottom: var(--space-xl);
  }

  .hero-wave {
    position: relative;
    z-index: 4;
    margin-top: -1px;
  }

  .hero-wave svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .section-heading {
    text-align: center;
    margin-bottom: var(--space-xl);
    color: var(--charcoal);
  }

  .amenities-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .amenity {
    padding: var(--space-md);
    background: var(--sand);
    border-radius: var(--radius);
    text-align: center;
  }

  .amenity-icon {
    color: var(--ocean);
    margin-bottom: var(--space-sm);
  }

  .amenity h3 {
    font-size: var(--font-size-lg);
    margin-bottom: 0.3em;
  }

  .amenity p {
    font-size: var(--font-size-sm);
    color: var(--warm-brown);
    line-height: 1.6;
  }

  .events-cta {
    background-color: var(--sand);
    padding: var(--space-xl) 0;
    margin-top: var(--space-lg);
  }

  .cta-card {
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 4px 30px oklch(0.25 0.015 60 / 0.08);
    display: grid;
    grid-template-columns: 1fr;
  }

  .cta-content {
    padding: var(--space-lg);
  }

  .cta-content h2 {
    margin-bottom: var(--space-sm);
  }

  .cta-content > p {
    font-size: var(--font-size-base);
    color: var(--warm-brown);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .contact-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    color: var(--warm-brown);
    margin-bottom: var(--space-sm);
  }

  .cta-details {
    padding: var(--space-lg);
    background: var(--sand);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .detail-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ocean);
  }

  .detail-value {
    font-size: var(--font-size-sm);
    color: var(--charcoal);
  }

  @media (min-width: 40rem) {
    .amenities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 60rem) {
    .amenities-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .cta-card {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }
</style>
